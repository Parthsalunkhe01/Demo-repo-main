# Environment Variables

# Server
PORT=5000

# JWT
JWT_SECRET=your_super_secret_jwt_key_here

# MongoDB — use local or Atlas URI
# Local:
MONGO_URI=mongodb://localhost:27017/complaint_portal
# Atlas example:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/complaint_portal?retryWrites=true&w=majority

# Uploads directory (optional, defaults to backend/uploads)
# UPLOADS_DIR=uploads
